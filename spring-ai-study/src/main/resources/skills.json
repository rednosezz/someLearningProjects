{
  "skills": [
    {
      "name": "weather-agent",
      "description": "天气问答助手，基于 Spring AI + Alibaba Cloud AI Graph 构建的 ReAct 风格 Agent",
      "endpoints": [
        {
          "path": "/agent/weather",
          "method": "GET",
          "parameters": {
            "message": {
              "type": "string",
              "required": true,
              "description": "天气查询问题，如：深圳今天天气怎么样"
            }
          }
        },
        {
          "path": "/agent/weatherWithUser",
          "method": "GET",
          "parameters": {
            "message": {
              "type": "string",
              "required": true,
              "description": "天气查询问题，若提到本地/当地/这里且没有城市信息，会自动通过userId获取用户所在城市"
            },
            "userId": {
              "type": "string",
              "required": true,
              "description": "用户ID，用于获取用户所在城市"
            }
          }
        }
      ],
      "responseFormat": {
        "type": "WeatherResponse",
        "fields": {
          "city": "城市名称",
          "weather": "天气状况（晴、阴、雨、雪等）",
          "tip": "穿着建议",
          "errorMessage": "异常说明（非必填）"
        }
      },
      "capabilities": [
        "根据城市名称查询天气",
        "根据用户ID自动获取用户所在城市并查询天气",
        "当用户提到本地/当地/这里等模糊表述时，自动先获取用户城市再查天气",
        "提供温度、天气状况（晴阴雨雪等）",
        "给出穿着建议"
      ],
      "tools": [
        {
          "name": "get_weather",
          "description": "获取某座城市天气"
        },
        {
          "name": "get_user_city",
          "description": "获取用户对应的城市地址"
        }
      ]
    }
  ]
}